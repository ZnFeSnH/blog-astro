---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="min-h-screen flex flex-col items-center justify-center bg-zinc-950 text-center px-6">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-white/5 text-xs tracking-[3px] mb-6 border border-white/10">
        EDGE SECURE • POWERED BY CLOUDFLARE
      </div>
      
      <h1 class="text-7xl font-bold tracking-[-4.5px] leading-none">Astro Edge CMS</h1>
      <p class="mt-6 text-2xl text-zinc-400 tracking-tight">现代 · 安全 · 边缘优先的博客系统</p>
      
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/blog" 
           class="px-10 py-4 rounded-2xl bg-white text-zinc-950 font-semibold text-lg hover:bg-zinc-200 active:scale-[0.985] transition-all">
          浏览博客
        </a>
        <a href="/admin" 
           class="px-10 py-4 rounded-2xl border border-white/30 hover:bg-white/5 font-semibold text-lg transition-all">
          进入管理后台
        </a>
      </div>
      
      <div class="mt-16 text-xs text-zinc-500 max-w-md mx-auto">
        静态生成 · D1 边缘数据库 · JWT + Zod + Rate Limit 多层防御<br>
        生产就绪 · 可零停机升级
      </div>
    </div>
  </div>
</BaseLayout>
