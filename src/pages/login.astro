---
export const prerender = false; // 👈 新增：登录页也必须是动态的
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md">
      <div class="glass rounded-2xl p-8 border border-white/10">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold tracking-tighter">Astro Edge CMS</h1>
          <p class="text-zinc-400 mt-2">安全管理后台登录</p>
        </div>

        <form id="login-form" class="space-y-6">
          <div>
            <label class="block text-sm font-medium mb-2">邮箱</label>
            <input 
              type="email" 
              name="email" 
              required 
              value="admin@yourblog.com"
              class="w-full px-4 py-3 bg-zinc-900 border border-white/20 rounded-xl focus:outline-none focus:border-blue-500"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">密码</label>
            <input 
              type="password" 
              name="password" 
              required 
              value="ChangeMe123!Secure"
              class="w-full px-4 py-3 bg-zinc-900 border border-white/20 rounded-xl focus:outline-none focus:border-blue-500"
            />
            <p class="text-[10px] text-amber-400 mt-1">演示账号：admin@yourblog.com / ChangeMe123!Secure （生产环境请立即更换）</p>
          </div>

          <button 
            type="submit"
            class="w-full py-3.5 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-200 active:scale-[0.985] transition-all"
          >
            安全登录
          </button>
        </form>

        <div id="error-msg" class="mt-4 text-red-400 text-sm hidden"></div>
      </div>
      
      <p class="text-center text-xs text-zinc-500 mt-6">
        受 Cloudflare Access / JWT + Zod + Rate Limit 保护<br>
        所有写入操作均经过严格校验与鉴权
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form');
  const errorEl = document.getElementById('error-msg');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const formData = new FormData(form);
    const payload = {
      email: formData.get('email'),
      password: formData.get('password')
    };

    try {
      const res = await fetch('/api/v1/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        credentials: 'include'
      });

      const data = await res.json();

      if (data.success) {
        window.location.href = '/admin';
      } else {
        errorEl.textContent = data.error?.message || '登录失败';
        errorEl.classList.remove('hidden');
      }
    } catch (err) {
      errorEl.textContent = '网络错误，请稍后重试';
      errorEl.classList.remove('hidden');
    }
  });
</script>